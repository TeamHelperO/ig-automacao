# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque-aqui-a-service-role-key

# Meta / Instagram (App do Instagram, produto "Instagram com Login do Instagram")
IG_APP_ID=coloque-aqui-o-id-do-app-do-instagram
IG_APP_SECRET=coloque-aqui-a-chave-secreta-do-app-do-instagram
IG_WEBHOOK_VERIFY_TOKEN=escolha-uma-string-aleatoria-qualquer

# URL pública do app (sem barra no final), ex: https://ig-automacao.vercel.app
APP_URL=https://seu-app.vercel.app

# Segredo para proteger os endpoints de cron (pg_cron vai mandar esse header)
CRON_SECRET=escolha-outra-string-aleatoria

# Senha simples para entrar no painel (/dashboard)
DASHBOARD_PASSWORD=escolha-uma-senha
